# ── Required for AI scoring + fit analysis ───────────────────────────────────
# OpenRouter — FREE tier available, no credit card needed
# Sign up at https://openrouter.ai → API Keys → Create key
# Free models: meta-llama/llama-3.3-70b-instruct:free, google/gemma-3-27b-it:free
OPENROUTER_API_KEY=your_key_here

# ── Optional: real company discovery (without this, uses mock data) ───────────
# Google Places API — https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=your_key_here

# ── Optional: contact enrichment ─────────────────────────────────────────────
# Hunter.io — https://hunter.io/api-keys
HUNTER_API_KEY=your_key_here

# ── Optional: search history persistence ─────────────────────────────────────
# Supabase — https://supabase.com
SUPABASE_URL=your_url_here
SUPABASE_KEY=your_key_here
