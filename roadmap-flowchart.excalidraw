      "groupIds": [], "frameId": null, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "Phase 2 — Engineering hardening", "fontSize": 20, "fontFamily": 1,
      "textAlign": "left", "verticalAlign": "top", "baseline": 18,
