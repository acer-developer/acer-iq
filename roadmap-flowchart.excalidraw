    {
      "id": "txtP2B", "type": "text", "x": 150, "y": 535, "width": 440, "height": 105,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1,
      "opacity": 100, "seed": 113, "version": 1, "versionNonce": 13, "isDeleted": false,
      "groupIds": [], "frameId": null, "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "• Structured logging + per-source status badges in UI\n• Cache + rate-limit every external call (BSE, LLM, geocode)\n• Auth + locked CORS, all state in Postgres\n• Batch LLM scoring — 1 call per search, not 30\n• Fix known bugs (2025 hardcode, CIN search, branding) + CI tests",
      "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 12,
      "containerId": null,
      "originalText": "• Structured logging + per-source status badges in UI\n• Cache + rate-limit every external call (BSE, LLM, geocode)\n• Auth + locked CORS, all state in Postgres\n• Batch LLM scoring — 1 call per search, not 30\n• Fix known bugs (2025 hardcode, CIN search, branding) + CI tests",
      "lineHeight": 1.25
    },
